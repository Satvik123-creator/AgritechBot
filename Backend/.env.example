# ═══════════════════════════════════════════════════════════
# Anaaj AI Backend — Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Server ──
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# ── MongoDB ──
MONGODB_URI=mongodb://localhost:27017/anaaj-ai
MONGODB_MAX_POOL_SIZE=50

# ── Redis ──
# Set to false to run without Redis (cache/queue disabled)
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Authentication ──
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ── Google Gemini (AI) ──
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.5-flash

# ── Sarvam AI (Voice) ──
SARVAM_API_KEY=your-sarvam-api-key
SARVAM_STT_URL=https://api.sarvam.ai/speech-to-text-translate
SARVAM_TTS_URL=https://api.sarvam.ai/text-to-speech

# ── ChromaDB (Vector DB) ──
# Set to false to disable RAG retrieval when ChromaDB is unavailable
RAG_ENABLED=true
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=agri_knowledge

# ── Rate Limiting ──
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ── Cache TTL (seconds) ──
CACHE_TTL=3600

# ── Queue ──
# Recommended: 10 for dev, 25-50 for production, 100+ for dedicated worker instances
QUEUE_CONCURRENCY=10

# ── Cluster mode ──
# 0 = auto-detect CPU cores, N = force N workers
CLUSTER_WORKERS=0

# ── OTP ──
OTP_EXPIRY_MINUTES=5

# ── Production-specific ──
# Comma-separated allowed origins for CORS (leave empty for permissive in dev)
CORS_ORIGINS=
# Override log level (debug, info, warn, error). Empty = auto-detect from NODE_ENV
LOG_LEVEL=

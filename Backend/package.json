{
  "name": "anaaj-ai-backend",
  "version": "1.0.0",
  "description": "Production-grade Agritech AI Assistant Backend",
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "prestart": "node scripts/free-port.js",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:cluster": "node dist/cluster.js",
    "worker": "tsx src/services/queue/worker.ts",
    "lint": "eslint src/",
    "seed": "tsx src/scripts/seed.ts",
    "kb:ingest": "tsx src/scripts/ingestKnowledge.ts",
    "loadtest:smoke": "artillery run loadtest/smoke-test.yml",
    "loadtest": "artillery run loadtest/load-test.yml",
    "loadtest:stress": "artillery run loadtest/stress-test.yml",
    "loadtest:report": "artillery run loadtest/load-test.yml --output loadtest/report.json && artillery report loadtest/report.json"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "@google/generative-ai": "^0.21.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.25.6",
    "chromadb": "^1.9.2",
    "dotenv": "^16.4.7",
    "fastify": "^5.1.0",
    "firebase-admin": "^13.7.0",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "openai": "^4.77.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/uuid": "^10.0.0",
    "artillery": "^2.0.30",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.1"
  }
}
